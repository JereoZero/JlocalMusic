#!/bin/bash
# Git pre-push hook — 确保推送前文档版本与 package.json 同步

set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
VERSION=$(node -p "require('$PROJECT_DIR/package.json').version")
EXIT_CODE=0

echo "🔍 Checking documentation version consistency (v$VERSION)..."

# 检查 docs/DEVELOPMENT_LOG.md
if grep -q "当前版本" "$PROJECT_DIR/docs/DEVELOPMENT_LOG.md" 2>/dev/null; then
  if ! grep -q "当前版本.*v$VERSION" "$PROJECT_DIR/docs/DEVELOPMENT_LOG.md"; then
    echo "❌ docs/DEVELOPMENT_LOG.md 版本号不是 v$VERSION"
    EXIT_CODE=1
  fi
fi

# 检查根目录 DEVELOPMENT_LOG.md
if [ -f "$PROJECT_DIR/DEVELOPMENT_LOG.md" ]; then
  if ! grep -q "v$VERSION" "$PROJECT_DIR/DEVELOPMENT_LOG.md" 2>/dev/null; then
    echo "❌ DEVELOPMENT_LOG.md 未包含 v$VERSION 条目"
    EXIT_CODE=1
  fi
fi

# 检查 CHANGELOG.md
if ! grep -q "## v$VERSION" "$PROJECT_DIR/CHANGELOG.md" 2>/dev/null; then
  echo "❌ CHANGELOG.md 缺少 v$VERSION 条目"
  EXIT_CODE=1
fi

# 检查 BUGS_HISTORY.md — 必须有对应版本条目
if [ -f "$PROJECT_DIR/docs/BUGS_HISTORY.md" ]; then
  if ! grep -q "v$VERSION" "$PROJECT_DIR/docs/BUGS_HISTORY.md" 2>/dev/null; then
    echo "❌ docs/BUGS_HISTORY.md 未包含 v$VERSION 条目"
    EXIT_CODE=1
  fi
fi

if [ $EXIT_CODE -ne 0 ]; then
  cat <<EOH

⚠️  文档版本不同步！请先运行以下命令同步：

    bash scripts/sync-docs.sh

然后手动更新以下文件中的 v$VERSION 相关条目：
  1. jlocal/CHANGELOG.md       — 添加 v$VERSION 更新日志
  2. jlocal/README.md          — 版本历史中添加 v$VERSION
  3. jlocal/README-zh.md       — 版本历史中添加 v$VERSION
  4. docs/DEVELOPMENT_LOG.md   — 添加 v$VERSION 开发记录
  5. docs/BUGS_HISTORY.md      — 添加 v$VERSION 修复记录
  6. DEVELOPMENT_LOG.md        — 更新当前版本状态

提交文档更新后再推送。

EOH
  exit 1
fi

echo "✅ All docs in sync with v$VERSION"