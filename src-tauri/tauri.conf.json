{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JlocalMusic",
  "version": "0.7.6",
  "identifier": "com.jlocalmusic.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "JlocalMusic",
        "url": "index.html",
        "width": 1200,
        "height": 750,
        "minWidth": 1200,
        "minHeight": 750,
        "maxWidth": 1200,
        "maxHeight": 750,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
